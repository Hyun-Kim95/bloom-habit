# PostgreSQL 연결 (필수)
# 형식: postgresql://사용자:비밀번호@호스트:포트/DB이름
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bloom_habit

# 서버 포트 (선택, 기본 3000)
# PORT=3000

# 관리자 초기 계정 (선택, 없으면 admin@bloom.local / admin123 사용)
# ADMIN_EMAIL=admin@bloom.local
# ADMIN_PASSWORD=admin123

# 비활성 계정 데이터 보관 일수(기본 365). 경과 후 배치가 습관·기록·문의 등 삭제 후 user 행 제거
# INACTIVE_USER_RETENTION_DAYS=365
# 매일 04:00 실행. 테스트용 cron 오버라이드 (예: "*/10 * * * *" = 10분마다)
# INACTIVE_USER_PURGE_CRON_OVERRIDE=
# 서버 기동 시 즉시 1회 실행 (개발용)
# INACTIVE_USER_PURGE_RUN_ON_START=true
