<?xml version="1.0" encoding="utf-8"?>
<!-- 개발용: LAN IP(http://192.168.x.x) 등 평문 HTTP 허용. 스토어 배포 전 HTTPS 전용으로 좁히는 것을 권장합니다. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
